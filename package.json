{
  "name": "srgdj",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:shared": "pnpm --filter @srgdj/shared dev",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "build:shared": "pnpm --filter @srgdj/shared build",
    "build": "pnpm build:shared && pnpm build:web && pnpm build:api",
    "typecheck": "pnpm build:shared && pnpm --filter @srgdj/shared typecheck && pnpm --filter web typecheck && pnpm --filter api typecheck",
    "lint": "pnpm --filter web lint",
    "test": "pnpm test:api",
    "test:api": "pnpm --filter api test",
    "test:web": "pnpm --filter web test"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
