# Evita truncar rutas en Windows (pnpm usa 60 por defecto si el path es largo),
# lo que rompe dependencias como tslib y paquetes @radix-ui/*.
virtual-store-dir-max-length=120

# Hace que dependencias transitivas (tslib) sean resolubles por Vite.
public-hoist-pattern[]=tslib
public-hoist-pattern[]=*@radix-ui/*
